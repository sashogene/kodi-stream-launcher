<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.streamlauncher"
       name="External Stream Launcher"
       version="1.0.0"
       provider-name="Sasho">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.pluginsource"
               library="default.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>External app library shortcuts</summary>
        <description>Launch external app titles directly from Kodi.</description>
        <platform>android</platform>
        <assets>
		    <icon>Kodi_launcher.png</icon>
	    </assets>
    </extension>
</addon>
